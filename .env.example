# =============================================================================
# UYE Mail Server — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# --- Identity -----------------------------------------------------------------

# Fully-qualified hostname of the mail server (used in SMTP banner, TLS certs)
MAIL_HOSTNAME=mail.example.com

# Primary mail domain (users will have addresses like user@MAIL_DOMAIN)
MAIL_DOMAIN=example.com

# Postmaster address (receives bounce/admin notifications)
POSTMASTER_EMAIL=postmaster@example.com

# Docker Compose project name (prefixes container/network names)
COMPOSE_PROJECT_NAME=uye-mail

# --- SendGrid Relay (production) ---------------------------------------------
# Create an API key at https://app.sendgrid.com/settings/api_keys
# Required permissions: Mail Send
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Rspamd ------------------------------------------------------------------
# Password for Rspamd web UI (http://host:11334)
# Plain text — DMS will hash it automatically on startup
RSPAMD_PASSWORD=changeme_rspamd_password

# --- Roundcube ---------------------------------------------------------------
# Exactly 24 characters — used for DES encryption of stored passwords
ROUNDCUBE_DES_KEY=changeme_24char_deskey!!

# --- TLS (production only) ---------------------------------------------------
# Absolute paths to TLS cert/key on the host (provided by uye-edge / certbot)
TLS_CERT_PATH=/etc/letsencrypt/live/mail.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/mail.example.com/privkey.pem

# --- Networking --------------------------------------------------------------
# Name of the shared Docker network created by uye-edge (prod)
UYE_NETWORK=uye-net

# --- Port Bindings -----------------------------------------------------------
# Adjust if these ports are already in use on the host.
# SMTP/IMAP ports are exposed directly (not routed through nginx).
SMTP_PORT=25
SUBMISSION_PORT=587
SUBMISSIONS_PORT=465
IMAP_PORT=143
IMAPS_PORT=993

# Rspamd web UI (dev: exposed on host; prod: proxy via nginx on uye-net)
RSPAMD_PORT=11334

# Roundcube web UI (dev only — in prod nginx picks it up via uye-net)
HTTP_ROUNDCUBE_PORT=8080

# Mailpit web UI (dev only)
HTTP_MAILPIT_PORT=8025
